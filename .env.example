# Contact form — copy this file to .env and fill in real values.
# .env is gitignored; never commit real secrets.

# Resend API key (https://resend.com/api-keys)
RESEND_API_KEY=

# Where enquiry emails are delivered.
CONTACT_TO_EMAIL=hello@example.com

# Verified Resend sender (must be on a domain you've verified in Resend).
CONTACT_FROM_EMAIL=MintCode <noreply@example.com>
